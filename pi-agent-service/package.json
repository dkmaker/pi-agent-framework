{
  "name": "pi-agent-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "pi-agent-service": "./src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "test": "tsx test/run-tests.ts",
    "test:integration": "tsx test/integration-test.ts",
    "lint": "biome check src/ test/",
    "format": "biome format --write src/ test/",
    "format:check": "biome format src/ test/",
    "e2e": "tsx test/e2e-alice-bob.ts"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.58.2",
    "@mariozechner/pi-coding-agent": "^0.58.2",
    "@sinclair/typebox": "^0.34.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
